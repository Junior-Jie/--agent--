# ============================================
# 2026-06-19 - Git 忽略规则
# 作用：告诉 Git 哪些文件不需要版本控制
# ============================================

# --- Python ---
__pycache__/                   # Python 自动生成的缓存目录
*.py[cod]                      # 编译后的 .pyc 文件
*.so                           # C 扩展编译产物
*.egg-info/                    # 包安装信息

# --- 虚拟环境 ---
venv/                          # 虚拟环境目录（太大，不提交）

# --- 环境变量（含 API Key，绝对不能提交！）---
.env                           # 你的真实密钥文件
.env.*                          # 任何 .env 的变体

# --- IDE ---
.idea/                         # PyCharm 项目配置
.vscode/                       # VS Code 配置
*.swp                          # Vim 临时文件

# --- 数据 ---
data/chroma_db/                # 向量数据库本地文件（本地生成，不提交）
*.db                           # SQLite 数据库文件
*.sqlite

# --- 日志 ---
logs/
*.log

# --- 系统文件 ---
.DS_Store                      # Mac 系统文件
Thumbs.db                      # Windows 缩略图缓存
